# ── LLM (required) ────────────────────────────────────────────────────────────
# Local Ollama (default). Use docker-compose.full.yml to run Ollama automatically.
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b"   # small/fast default; use qwen3:14b for best quality

# OpenAI or compatible API (alternative to Ollama — leave blank if using Ollama)
OPENAI_API_KEY=
# OLLAMA_BASE_URL="https://api.openai.com/v1"  # uncomment to use OpenAI

# ── Web search (optional) ──────────────────────────────────────────────────────
# Without a key the agent falls back to DuckDuckGo automatically.
# Free tier at https://tavily.com gives 1 000 req/month.
TAVILY_API_KEY=

# ── Source enrichment (optional) ──────────────────────────────────────────────
GITHUB_TOKEN=       # improves GitHub search results
YOUTUBE_API_KEY=    # required only for YouTube transcript source

# ── Email delivery (optional) ──────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# ── Performance ────────────────────────────────────────────────────────────────
MAX_RESULTS_PER_SOURCE="5"
MAX_CONCURRENT_REQUESTS="5"
CACHE_EXPIRY_HOURS="24"
REQUEST_TIMEOUT="30"
LOG_LEVEL="INFO"