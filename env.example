# ── LLM (required — pick one backend) ────────────────────────────────────────

# Option A: Local Ollama (default, zero cost)
# docker-compose.full.yml runs Ollama automatically; or install from https://ollama.com
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:1.5b"   # ~1 GB; use qwen3:14b for best quality

# Option B: Groq — free tier, very fast, no credit card needed
# Get a key at https://console.groq.com (takes 2 minutes)
# OPENAI_API_KEY="gsk_..."
# OLLAMA_BASE_URL="https://api.groq.com/openai/v1"
# OLLAMA_MODEL="llama-3.1-8b-instant"   # or llama-3.3-70b-versatile

# Option C: Google Gemini — free tier (1 000 req/day)
# Get a key at https://aistudio.google.com
# OPENAI_API_KEY="AIza..."
# OLLAMA_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
# OLLAMA_MODEL="gemini-1.5-flash"

# Option D: OpenAI
# OPENAI_API_KEY="sk-..."
# OLLAMA_BASE_URL="https://api.openai.com/v1"
# OLLAMA_MODEL="gpt-4o-mini"

OPENAI_API_KEY=

# ── Web search (optional) ──────────────────────────────────────────────────────
# Without a key the agent falls back to DuckDuckGo automatically.
# Free tier at https://tavily.com gives 1 000 req/month.
TAVILY_API_KEY=

# ── Source enrichment (optional) ──────────────────────────────────────────────
GITHUB_TOKEN=       # improves GitHub search results
YOUTUBE_API_KEY=    # required only for YouTube transcript source

# ── Email delivery (optional) ──────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# ── Performance ────────────────────────────────────────────────────────────────
MAX_RESULTS_PER_SOURCE="5"
MAX_CONCURRENT_REQUESTS="5"
CACHE_EXPIRY_HOURS="24"
REQUEST_TIMEOUT="30"
LOG_LEVEL="INFO"